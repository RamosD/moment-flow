# Dependencies
node_modules/

# Build output
dist/
*.tsbuildinfo

# Test coverage
coverage/

# Environment (never commit real secrets — see .env.example)
.env
.env.*
!.env.example
!.env.e2e.example

# Local renderer storage (generated assets). Anchored to the project root so
# it does NOT also match src/storage/ (the storage provider source code) —
# an unanchored "storage/" pattern would silently hide that from git.
/storage/

# E2E harness logs/artifacts
e2e-logs/

# Logs
*.log
npm-debug.log*

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/

# =============================================================================
# Content / Report Renderer — environment template
# Copy to `.env` and adjust. NEVER commit a real `.env` with secrets.
# =============================================================================

# HTTP port the renderer listens on.
PORT=8202

# Runtime environment: development | production | test
NODE_ENV=development

# Shared secret used to authenticate internal calls between Django and the
# renderer (header `X-Internal-Token`). Must match the value configured in the
# Backend Core. MUST NOT be empty in production.
INTERNAL_API_TOKEN=

# Insecure local mode (development only). When set to `true`, the renderer is
# allowed to boot with an EMPTY INTERNAL_API_TOKEN. This disables internal
# authentication and must only ever be used for local development. It is
# rejected in production.
ALLOW_INSECURE_EMPTY_TOKEN=false

# Public base URL where this renderer is reachable.
RENDERER_PUBLIC_BASE_URL=http://localhost:8202

# Base URL of the Backend Core (Django) — used for callbacks.
BACKEND_CORE_BASE_URL=http://localhost:8100

# Storage backend (R-HARD-005, extended by STG-LOCAL-004). `local` (default)
# is the filesystem provider used for dev; `s3` is the S3-compatible provider
# validated against a local MinIO container for staging local formal — see
# frontend/docs/01_fundamentos/06_staging_infraestrutura_real_local/. `r2`/`gcs`
# are NOT implemented. An unknown value fails fast at boot.
STORAGE_PROVIDER=local

# Root directory for local asset storage (dev default — NOT staging/production
# storage; STORAGE_PROVIDER=s3 is the target for staging local formal).
LOCAL_STORAGE_ROOT=./storage

# Public base URL where locally stored files are served from (dev only). This
# value is what ends up in the callback's `asset.public_url` and, since
# STG-PRE-003, is persisted verbatim on the Backend Core's `Asset.public_url`
# (surfaced via `GET /api/v1/assets/{id}/`). Only read when STORAGE_PROVIDER=local.
LOCAL_STORAGE_PUBLIC_BASE_URL=http://localhost:8202/files

# --- S3-compatible storage (STG-LOCAL-004) — only used when STORAGE_PROVIDER=s3 ---
# All four variables below are REQUIRED when STORAGE_PROVIDER=s3 (boot fails
# fast otherwise); they are ignored when STORAGE_PROVIDER=local.

# Endpoint of the S3-compatible service. For the local staging MinIO container
# (see docker-compose.staging.local.yml at the repo root): http://127.0.0.1:9000.
STORAGE_ENDPOINT=

# Bucket used for staging artefacts. Must already exist (the local MinIO
# compose creates it automatically via the `minio-bucket-init` service).
STORAGE_BUCKET=

# Access key / secret key for the S3-compatible service. For local MinIO these
# are MINIO_ROOT_USER / MINIO_ROOT_PASSWORD from .env.staging.local at the repo
# root. NEVER commit real values — this is a secret.
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

# Region string required by the S3 SDK; MinIO ignores its value but the SDK
# still requires one to be set. Safe to leave at the default for MinIO.
STORAGE_REGION=us-east-1

# Path-style addressing (http://endpoint/bucket/key) instead of virtual-hosted
# style (http://bucket.endpoint/key). Required for MinIO and most self-hosted
# S3-compatible endpoints — leave at the default (true) for local staging.
STORAGE_FORCE_PATH_STYLE=true

# Public base URL used to build asset.public_url. Optional — defaults to
# "<STORAGE_ENDPOINT>/<STORAGE_BUCKET>" (path-style) when unset, which is
# correct for the local MinIO container reachable at STORAGE_ENDPOINT.
STORAGE_PUBLIC_BASE_URL=

# Maximum accepted job payload size, in bytes (default 1 MiB).
MAX_JOB_PAYLOAD_BYTES=1048576

# Timeout (seconds) when calling the Django callback endpoint (per attempt).
CALLBACK_TIMEOUT_SECONDS=20

# Callback retry/backoff (R-HARD-006). The renderer retries the callback on
# transient failures (network error, timeout, HTTP 500/502/503/504) and does NOT
# retry on 4xx (400/401/403/404/409/422). Total time is bounded — never an
# infinite loop.
#  - CALLBACK_MAX_ATTEMPTS: total delivery attempts (>= 1; 1 disables retry).
#  - CALLBACK_RETRY_BASE_DELAY_MS: base backoff delay in ms (>= 0). Doubles each
#    attempt (exponential), capped by the max below.
#  - CALLBACK_RETRY_MAX_DELAY_MS: upper bound for the backoff delay in ms
#    (must be >= CALLBACK_RETRY_BASE_DELAY_MS).
CALLBACK_MAX_ATTEMPTS=3
CALLBACK_RETRY_BASE_DELAY_MS=500
CALLBACK_RETRY_MAX_DELAY_MS=5000

# Timeout (seconds) for a single render operation.
RENDER_TIMEOUT_SECONDS=30

# Preferred output format for report_generation: auto | pdf | html
#  - auto (default): generate a PDF, fall back to HTML if PDF is unavailable;
#  - pdf: PDF preferred (HTML kept as a safety fallback);
#  - html: emit HTML only (for constrained environments without a PDF engine).
REPORT_OUTPUT_FORMAT=auto

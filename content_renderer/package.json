{
  "name": "content_renderer",
  "version": "0.1.0",
  "private": true,
  "description": "ChartRex / MomentFlow Content & Report Renderer — generates visual assets from jobs dispatched by the Backend Core (Django).",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=18.18"
  },
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "chartrex",
    "momentflow",
    "renderer",
    "content",
    "report"
  ],
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "pdf-lib": "^1.17.1",
    "sharp": "^0.35.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  }
}

# =============================================================================
# E2E harness environment (PostgreSQL) — R-HARD-002
# Copy to `.env.e2e` to override the harness defaults. These are DEVELOPMENT
# values, NOT secrets and NOT for production. NEVER put real secrets here.
# `.env.e2e` is git-ignored; only this `.example` is committed.
# =============================================================================

# Shared internal token — MUST be identical in the renderer and backend_core.
# The harness generates an ephemeral token if this is left at the placeholder.
INTERNAL_API_TOKEN=e2e-shared-token-change-me

# --- PostgreSQL (must match docker-compose.e2e.yml) --------------------------
DB_ENGINE=postgres
DB_NAME=chartrex_e2e
DB_USER=chartrex_e2e
DB_PASSWORD=chartrex_e2e_dev_only
DB_HOST=localhost
DB_PORT=55432

# --- Service URLs / flags ----------------------------------------------------
PORT=8202
NODE_ENV=development
LOG_LEVEL=warn
STORAGE_PROVIDER=local
BACKEND_CORE_BASE_URL=http://localhost:8100
BACKEND_PUBLIC_BASE_URL=http://localhost:8100
CONTENT_RENDERER_BASE_URL=http://localhost:8202
# The single renderer serves report/media-kit too (report_renderer provider).
REPORT_RENDERER_BASE_URL=http://localhost:8202
INTERNAL_CALLBACK_PATH=/api/v1/internal/jobs/callback/
EXTERNAL_JOBS_ENABLED=true
EXTERNAL_JOBS_DRY_RUN=false

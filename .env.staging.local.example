# =============================================================================
# Infraestrutura de staging local (PostgreSQL + MinIO) — exemplo de env
# Copiar para `.env.staging.local` (ignorado pelo git) e ajustar os valores.
# NUNCA commitar `.env.staging.local` com valores reais.
#
# Usado por: docker-compose.staging.local.yml
# Consumido também pelo Backend Core (DB_*) e pelo Content Renderer
# (STORAGE_*) quando estes forem apontados para esta infraestrutura local
# (ver STG-LOCAL-003 e STG-LOCAL-004 — fora do âmbito deste ficheiro).
# =============================================================================

# --- PostgreSQL (container) ---
POSTGRES_DB=chartrex_staging
POSTGRES_USER=chartrex_staging
# Definir um valor local próprio; nunca reutilizar um password real.
POSTGRES_PASSWORD=change-me-local-only
# Override se a porta 5432 já estiver ocupada por outra instância local.
POSTGRES_PORT=5432

# --- MinIO (container) ---
MINIO_ROOT_USER=chartrex_staging_minio
# Mínimo 8 caracteres (exigido pelo MinIO). Definir um valor local próprio.
MINIO_ROOT_PASSWORD=change-me-local-only
# Overrides se as portas 9000/9001 já estiverem ocupadas.
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- Bucket de staging (criado automaticamente pelo serviço minio-bucket-init) ---
STORAGE_BUCKET=chartrex-staging

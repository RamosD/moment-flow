# Intelligence Engine — environment variables
# Copy this file to .env and adjust the values. Never commit the real .env.

# Runtime environment: development | production | test
APP_ENV=development

# Service identification (also exposed in GET /health)
SERVICE_NAME=intelligence_engine
SERVICE_VERSION=0.1.0

# Logging level for the structured JSON logger.
LOG_LEVEL=INFO

# Shared secret used to authenticate internal calls from the Backend Core
# (header X-Internal-Token), checked by app/core/security.py on every
# protected endpoint. GET /health is always public and never requires it.
#
# Rules:
#  - production: MUST be non-empty. An empty value here fails the service at
#    boot with a config_error (Settings() raises before the app can start).
#  - development/test: an empty value is allowed, but it is NOT an insecure
#    bypass — when no token is configured, every protected endpoint rejects
#    every request (403 unauthorized_internal_request), since there is
#    nothing valid to compare against. Set a token below to exercise
#    protected endpoints locally.
#
# MUST NOT be a real secret here. Never commit a real value.
INTERNAL_API_TOKEN=

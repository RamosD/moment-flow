# Frontend environment configuration.
# Copy this file to `.env.local` and adjust as needed.
#
# Base URL of the Backend Core API — the ONLY backend the frontend talks to.
# Must include the /api/v1 prefix and use http(s).
# In development this defaults to http://localhost:8000/api/v1 if unset.
VITE_BACKEND_API_BASE_URL=http://localhost:8000/api/v1

# NOTE: never add X-Internal-Token or any service-to-service secret here.
# Those are backend-only and must never reach the browser.

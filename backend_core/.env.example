# ChartRex Backend Core — environment variables
# Copy this file to .env and adjust the values. Never commit the real .env.

# --- Django core ---
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- CORS (comma-separated origins) ---
CORS_ALLOWED_ORIGINS=http://localhost:5200,http://127.0.0.1:5200

# --- Database ---
# Defaults to SQLite. Set DB_ENGINE=postgres to use PostgreSQL.
DB_ENGINE=sqlite
DB_NAME=chartrex
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# --- JWT (SimpleJWT) ---
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7

# --- Billing / Stripe (skeleton) ---
# Leave empty in local/dev. When STRIPE_WEBHOOK_SECRET is set, the webhook
# endpoint verifies the Stripe-Signature header; otherwise signatures are not
# verified (documented limitation). Never commit real keys.
STRIPE_WEBHOOK_SECRET=
STRIPE_API_KEY=

# --- Internal service-to-service token ---
# Shared secret for internal callbacks from FastAPI/renderer/workers
# (header X-Internal-Token). When empty, internal endpoints reject all calls.
# This is a secret — never commit a real value.
INTERNAL_API_TOKEN=

# --- External technical services (FastAPI / renderers) ---
# Django orchestrates; these services calculate and render. URLs/timeouts only,
# no secrets. Leave the defaults for local development.
BACKEND_PUBLIC_BASE_URL=http://localhost:8100

INTELLIGENCE_ENGINE_BASE_URL=http://localhost:8201
INTELLIGENCE_ENGINE_TIMEOUT_SECONDS=10
# Synchronous Intelligence Engine path (independent from EXTERNAL_JOBS_* above).
#   INTELLIGENCE_ENGINE_ENABLED=false → the sync client is not called.
#   INTELLIGENCE_ENGINE_DRY_RUN=true  → a deterministic stub is returned (no HTTP).
INTELLIGENCE_ENGINE_ENABLED=true
INTELLIGENCE_ENGINE_DRY_RUN=false
# Minimal retry for transient failures only (timeout/unreachable/5xx); 4xx is
# never retried. Retries run inside the user request, so keep them small.
INTELLIGENCE_ENGINE_MAX_RETRIES=1
INTELLIGENCE_ENGINE_RETRY_BACKOFF_SECONDS=0.5
# Internal token for the Intelligence Engine. Leave EMPTY to reuse the shared
# INTERNAL_API_TOKEN above (recommended — same secret on both services). Only set
# this if you need a per-service token. This is a secret — never commit a real
# value. In production (DEBUG=False) the app refuses to boot if this resolves to
# empty while the engine is enabled and not in dry-run.
INTELLIGENCE_ENGINE_INTERNAL_TOKEN=

CONTENT_RENDERER_BASE_URL=http://localhost:8202
CONTENT_RENDERER_TIMEOUT_SECONDS=30

REPORT_RENDERER_BASE_URL=http://localhost:8202
REPORT_RENDERER_TIMEOUT_SECONDS=30

# Path the external services call back to (combined with BACKEND_PUBLIC_BASE_URL).
INTERNAL_CALLBACK_PATH=/api/v1/internal/jobs/callback/

# Master switches for external job submission.
#   EXTERNAL_JOBS_ENABLED=false → jobs are created but stay queued (no call).
#   EXTERNAL_JOBS_DRY_RUN=true  → submission is simulated (no real HTTP call).
# Useful locally while FastAPI/renderers do not exist yet.
EXTERNAL_JOBS_ENABLED=true
EXTERNAL_JOBS_DRY_RUN=false

# Aggregated dependency healthcheck (GET /api/v1/system/health/dependencies/).
# Short, fail-fast timeout (seconds) for probing the external services' public
# /health. No token is ever sent on this probe. Keep it low.
HEALTHCHECK_DEPENDENCY_TIMEOUT_SECONDS=2
